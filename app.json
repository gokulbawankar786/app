{
  "expo": {
    "name": "PharmaLink",
    "slug": "pharmalink",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#00b86b"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "in.pharmalink.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "PharmaLink needs your location to show nearby stockists.",
        "NSLocationAlwaysUsageDescription": "PharmaLink needs your location to show nearby stockists."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#00b86b"
      },
      "package": "in.pharmalink.app",
      "versionCode": 1,
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION", "RECEIVE_BOOT_COMPLETED", "VIBRATE"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      ["expo-notifications", {
        "icon": "./assets/notification-icon.png",
        "color": "#00b86b"
      }],
      ["expo-location", {
        "locationAlwaysAndWhenInUsePermission": "PharmaLink needs location access to show nearby stockists."
      }]
    ],
    "extra": {
      "apiUrl": "https://api.pharmalink.in",
      "eas": { "projectId": "your-eas-project-id" }
    },
    "owner": "pharmalink"
  }
}
